# RequestBite brick environment configuration
#
# Copy this file to .env.dev (or .env) and fill in OAUTH_CLIENT_ID once a
# brick OIDC client has been created. The API URLs below point at the same
# local dev backend used by rbite.

ACC_API_URL=http://localhost:8080
STORAGE_API_URL=http://localhost:8081

# OIDC client for brick — requests the "brick:manage" scope. Leave blank
# until a client has been registered; --login fails fast with a clear error
# until this is set.
OAUTH_CLIENT_ID=
OAUTH_SCOPES=openid email profile accounts offline_access brick:manage
OAUTH_CALLBACK_URL=http://localhost:7332/auth/callback

# Debug mode (set to "true" to enable debug logging)
DEBUG=false
